        "z": "3b81866a7566c023",
        "name": "Quay về vị trí ban đầu",
        "func": "// Quay servo về vị trí ban đầu (90 độ - giữa)\nmsg.payload = {\n    servo_pan: 90,\n    servo_tilt: 90,\n    action: 'return_home',\n    timestamp: new Date().toISOString()\n};\n\n// Tắt máy bơm\nlet pumpMsg = {\n    payload: {\n        relay2: 0,\n        timestamp: new Date().toISOString()\n    },\n    topic: 'pccc/esp32/relay'\n};\n\n// Reset trạng thái\ncontext.set('is_spraying', false);\n\nreturn [msg, pumpMsg];",
