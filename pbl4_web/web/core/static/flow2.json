    {
        "id": "1223acae93486105",
        "type": "function",
        "z": "3b81866a7566c023",
        "name": "Xử lý cảm biến",
        "func": "// Xử lý dữ liệu từ ESP32\n// Format: {smoke: value, gas: value, relay2: state, timestamp: time}\n\nlet data = msg.payload;\n\n// Lưu vào context để tracking\ncontext.set('smoke', data.smoke);\ncontext.set('gas', data.gas);\ncontext.set('relay2', data.relay2);\n\n// Kiểm tra ngưỡng nguy hiểm\nlet alert = false;\nlet alertMsg = [];\n\nif (data.smoke > 1500) {\n    alert = true;\n    alertMsg.push('Khói vượt ngưỡng: ' + data.smoke);\n}\n\nif (data.gas > 1500) {\n    alert = true;\n    alertMsg.push('Gas vượt ngưỡng: ' + data.gas);\n}\n\nif (alert) {\n    msg.payload = {\n        alert: true,\n        message: alertMsg.join(', '),\n        sensors: data,\n        timestamp: new Date().toISOString()\n    };\n    return [msg, null];\n} else {\n    msg.payload = {\n        alert: false,\n        sensors: data,\n        timestamp: new Date().toISOString()\n    };\n    return [null, msg];\n}",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 460,
        "y": 280,
        "wires": [
            [
                "f0e2e92143fa67aa"
            ],
            [
                "2589795afd5d4424"
            ]
        ]
    },
    {
        "id": "9e3bd7713417ac5a",
        "type": "function",
        "z": "3b81866a7566c023",
        "name": "Xử lý AI Detection",
        "func": "// Xử lý kết quả từ AI\n// Format: {detected: true/false, type: 'fire'/'smoke', confidence: 0.95, position: {x: 320, y: 240}, bbox: {x1, y1, x2, y2}}\n\nlet data = msg.payload;\n\nif (data.detected && data.confidence > 0.7) {\n    // Tính góc quay servo dựa trên vị trí phát hiện\n    // Giả sử camera 640x480, servo quay 0-180 độ\n    let imageWidth = 640;\n    let servoMin = 0;\n    let servoMax = 180;\n    \n    // Tính góc quay ngang (pan)\n    let panAngle = Math.round((data.position.x / imageWidth) * (servoMax - servoMin) + servoMin);\n    \n    // Tính góc quay dọc (tilt) nếu cần\n    let imageHeight = 480;\n    let tiltAngle = Math.round((data.position.y / imageHeight) * (servoMax - servoMin) + servoMin);\n    \n    msg.payload = {\n        fire_detected: true,\n        type: data.type,\n        confidence: data.confidence,\n        servo_pan: panAngle,\n        servo_tilt: tiltAngle,\n        position: data.position,\n        bbox: data.bbox,\n        timestamp: new Date().toISOString()\n    };\n    \n    // Lưu vào context\n    context.set('last_detection', msg.payload);\n    \n    return msg;\n} else {\n    return null;\n}",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 470,
        "y": 500,
        "wires": [
            [
                "ab5d47bfda6ccc69",
                "fc7ac419975653ae"
            ]
        ]
    },
    {
        "id": "ab5d47bfda6ccc69",
        "type": "function",
        "z": "3b81866a7566c023",
        "name": "Tính toán góc Servo",
        "func": "// Nhận thông tin từ AI và tính toán góc servo chính xác\nlet detection = msg.payload;\n\n// Kiểm tra xem có đang phun không\nlet isSpraying = context.get('is_spraying') || false;\n\nif (!isSpraying) {\n    // Gửi lệnh điều khiển servo\n    msg.payload = {\n        servo_pan: detection.servo_pan,\n        servo_tilt: detection.servo_tilt,\n        action: 'move',\n        timestamp: new Date().toISOString()\n    };\n    \n    // Đánh dấu đang phun\n    context.set('is_spraying', true);\n    context.set('spray_start', Date.now());\n    \n    return msg;\n} else {\n    node.warn('Đang trong quá trình phun nước');\n    return null;\n}",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 760,
        "y": 500,
