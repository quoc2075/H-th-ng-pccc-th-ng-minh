    {
        "id": "7c063f5d8e2e87f3",
        "type": "function",
        "z": "3b81866a7566c023",
        "name": "Kiểm tra trạng thái hệ thống",
        "func": "// Kiểm tra trạng thái hoạt động của ESP32\nlet status = msg.payload;\n\n// Lưu thời gian nhận được status\nlet lastSeen = context.get('esp32_last_seen') || [];\nlastSeen.push(Date.now());\n\n// Chỉ giữ 10 lần gần nhất\nif (lastSeen.length > 10) {\n    lastSeen.shift();\n}\ncontext.set('esp32_last_seen', lastSeen);\n\n// Kiểm tra kết nối ổn định\nlet isStable = true;\nif (lastSeen.length >= 2) {\n    let intervals = [];\n    for (let i = 1; i < lastSeen.length; i++) {\n        intervals.push(lastSeen[i] - lastSeen[i-1]);\n    }\n    let avgInterval = intervals.reduce((a, b) => a + b, 0) / intervals.length;\n    \n    // Nếu khoảng cách trung bình > 30s thì không ổn định\n    if (avgInterval > 30000) {\n        isStable = false;\n    }\n}\n\nmsg.payload = {\n    esp32_status: status,\n    connection_stable: isStable,\n    last_seen: lastSeen[lastSeen.length - 1],\n    avg_interval: lastSeen.length >= 2 ? \n        Math.round((lastSeen[lastSeen.length - 1] - lastSeen[0]) / (lastSeen.length - 1) / 1000) : 0,\n    timestamp: new Date().toISOString()\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
