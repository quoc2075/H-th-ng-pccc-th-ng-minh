    {
        "id": "c1b61e4a975396ef",
        "type": "function",
        "z": "54920bdd45f23848",
        "name": "Xử lý cảm biến",
        "func": "// ✅ FORMAT MỚI: {smoke, gas, relay1, relay2, servo_pan, servo_tilt, timestamp}\n\nlet data = msg.payload;\n\n// Lưu vào context để tracking\ncontext.set('smoke', data.smoke || 0);\ncontext.set('gas', data.gas || 0);\ncontext.set('relay1', data.relay1 || 0);  // ✅ Đèn + Còi\ncontext.set('relay2', data.relay2 || 0);  // ✅ Máy bơm\ncontext.set('servo_pan', data.servo_pan || 90);\ncontext.set('servo_tilt', data.servo_tilt || 90);\n\n// Kiểm tra ngưỡng nguy hiểm\nlet alert = false;\nlet alertMsg = [];\n\nif (data.smoke > 1500) {\n    alert = true;\n    alertMsg.push('Khói vượt ngưỡng: ' + data.smoke);\n}\n\nif (data.gas > 1500) {\n    alert = true;\n    alertMsg.push('Gas vượt ngưỡng: ' + data.gas);\n}\n\nif (alert) {\n    // ✅ Bật Relay 1 (Đèn + Còi) khi có cảnh báo từ sensor\n    let relay1Msg = {\n        payload: {\n            relay1: 1,\n            timestamp: Date.now()\n        },\n        topic: 'pccc/esp32/relay'\n    };\n    \n    msg.payload = {\n        alert: true,\n        message: alertMsg.join(', '),\n        sensors: data,\n        timestamp: new Date().toISOString()\n    };\n    \n    return [msg, null, relay1Msg];\n} else {\n    msg.payload = {\n        alert: false,\n        sensors: data,\n        timestamp: new Date().toISOString()\n    };\n    return [null, msg, null];\n}",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 450,
        "y": 140,
        "wires": [
            [
                "9fe1de78491bcd83"
            ],
            [
                "4b3105f9451806cd"
            ],
            [
                "a7208c9694d9a293"
            ]
        ]
    },
    {
        "id": "9b78d50c3a3c9aef",
        "type": "function",
        "z": "54920bdd45f23848",
        "name": "Xử lý AI Detection",
        "func": "// ✅ XỬ LÝ FORMAT MỚI: {type: \"fire\"/\"smoke\"/\"safe\", conf, timestamp}\n\nlet data = msg.payload;\n\nif (data.type === \"fire\" || data.type === \"smoke\") {\n    // AI phát hiện lửa/khói\n    node.warn(`🔥 AI DETECTED: ${data.type} (${data.conf})`);\n    \n    // ✅ Bật Relay 1 (Đèn + Còi)\n    let relay1Msg = {\n        payload: {\n            relay1: 1,\n            timestamp: Date.now()\n        },\n        topic: 'pccc/esp32/relay'\n    };\n    \n    msg.payload = {\n        fire_detected: true,\n        type: data.type,\n        confidence: data.conf,\n        timestamp: new Date().toISOString()\n    };\n    \n    context.set('last_detection', msg.payload);\n    context.set('ai_fire_active', true);\n    \n    // Output: [servo_control, relay1_control, pump_control]\n    return [msg, relay1Msg, msg];\n    \n} else if (data.type === \"safe\") {\n    // AI không phát hiện nguy hiểm\n    node.status({fill:\"green\", shape:\"dot\", text:\"Safe\"});\n    \n    // ✅ Tắt Relay 1 (Đèn + Còi)\n    let relay1Msg = {\n        payload: {\n            relay1: 0,\n            timestamp: Date.now()\n        },\n        topic: 'pccc/esp32/relay'\n    };\n    \n    context.set('ai_fire_active', false);\n    \n    return [null, relay1Msg, null];\n}\n\nreturn null;",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 450,
        "y": 320,
        "wires": [
            [
                "8247a9ad260f9e5c"
            ],
            [
                "a7208c9694d9a293"
            ],
            [
                "1e4222171040e5ab"
            ]
        ]
    },
    {
        "id": "8247a9ad260f9e5c",
        "type": "function",
        "z": "54920bdd45f23848",
        "name": "Tính toán góc Servo",
        "func": "// ✅ SERVO ĐƯỢC ĐIỀU KHIỂN TỰ ĐỘNG BỞI DJANGO AI\n// Node-RED chỉ forward command từ Django\n\nlet detection = msg.payload;\n\nif (detection.fire_detected) {\n    // Kiểm tra xem có đang phun không\n    let isSpraying = context.get('is_spraying') || false;\n    \n    if (!isSpraying) {\n        // Gửi lệnh điều khiển servo\n        msg.payload = {\n            servo_pan: 90,  // Default, Django AI sẽ điều khiển\n            action: 'move',\n            timestamp: new Date().toISOString()\n        };\n        \n        context.set('is_spraying', true);\n        context.set('spray_start', Date.now());\n        \n        return msg;\n    } else {\n        node.warn('Đang trong quá trình phun nước');\n        return null;\n    }\n} else {\n    return null;\n}",
