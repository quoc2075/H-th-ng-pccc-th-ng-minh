        "id": "50afedea60b27efc",
        "type": "function",
        "z": "54920bdd45f23848",
        "name": "Quay về vị trí ban đầu",
        "func": "// Quay servo về vị trí ban đầu (90 độ)\nmsg.payload = {\n    servo_pan: 0,  // ✅ Django AI điều khiển về 0\n    action: 'return_home',\n    timestamp: new Date().toISOString()\n};\n\n// ✅ Tắt máy bơm (Relay 2)\nlet pumpMsg = {\n    payload: {\n        relay2: 0,\n        timestamp: new Date().toISOString()\n    },\n    topic: 'pccc/esp32/relay'\n};\n\n// Reset trạng thái\ncontext.set('is_spraying', false);\n\nreturn [msg, pumpMsg];",
